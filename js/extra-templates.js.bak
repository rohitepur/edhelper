                return { q: `What is the remainder when ${num} is divided by ${divisor}?`, ans: rem.toString(), distractors: [quotient.toString(), divisor.toString(), "0"], guide: `${divisor} × ${quotient} = ${divisor*quotient}. ${num} - ${divisor*quotient} = ${rem}.` };
