                return {
                    q: `James makes ${b} bookmarks. He uses ${a} inches of ribbon for each. How many inches does he use in total?`,
                    ans: ans.toString(),
                    distractors: [(a + b).toString(), (a * bBase).toString(), (ans + 10).toString()],
