                    q: `Find the slope between (0, ${y1}) and (2, ${y2}).`,
                    ans: slope.toString(),
                    distractors: ["2", rise.toString(), "0.5"],
                    guide: `Slope = (y2 - y1) / (x2 - x1) = (${y2} - ${y1}) / (2 - 0) = ${rise} / 2 = ${slope}.`
                };
            }},

            { type: "SlopeWordProblem", anchor: "A1.2.2.1.1", openEnded: false, gen: () => {
                const rate = rand(15, 30);
