                    distractors: [`${a}x`, `x² + 1`, `x`],
                    guide: `Factor the numerator: ${a}x(x + 1). Divide by ${a}x to leave x + 1.`
                };
            }},

            { type: "LiteralEquations", anchor: "A1.1.2.1.1", openEnded: false, gen: () => ({
