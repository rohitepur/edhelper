                    guide: `Round ${p1.toFixed(2)} to ${Math.round(p1)} and ${p2.toFixed(1)} to ${Math.round(p2)}. Multiply: ${Math.round(p1)} × ${Math.round(p2)} = ${ans}.`
                };
